objekts suga {
    tk nosaukums
    sk gads
}
objekts koks {
    suga suga
    sk augstums
    sk diametrs
}

koks koks1 : {suga: "egle" augstums: 4 diametrs:5}
funkc testfun(&sk arguments) {
    arguments : "egle"
}

testfun(koks1.suga.nosaukums)
izvade(koks1) // Izvada 5


