objekts koks {
    tk suga
    sk augstums
    sk diametrs
}

koks koks1 : {suga: "a" augstums: 4 diametrs:5}
funkc testfun(&tk arguments) {
    arguments : "egle"
}

testfun(koks1.suga)
izvade(koks1) // Izvada 5


